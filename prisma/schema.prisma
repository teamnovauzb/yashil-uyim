generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  telegramId BigInt   @id @map("telegram_id")
  username   String?
  firstName  String?  @map("first_name")
  lastName   String?  @map("last_name")
  phone      String?
  isTester   Boolean  @default(false) @map("is_tester")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("users")
}

model Ticket {
  id              BigInt    @id @default(autoincrement())
  ticketNumber    Int?      @unique @map("ticket_number")
  fullName        String    @map("full_name")
  phone           String
  ticketCount     Int       @default(1) @map("ticket_count")
  status          String    @default("pending")
  chatId          BigInt?   @map("chat_id")
  receiptUrl      String?   @map("receipt_url")
  qrToken         String?   @unique @map("qr_token")
  qrUrl           String?   @map("qr_url")
  checkedInCount  Int       @default(0) @map("checked_in_count")
  lastCheckinAt   DateTime? @map("last_checkin_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  seats           TicketSeat[]

  @@map("tickets")
}

model TicketSeat {
  ticketId      BigInt    @map("ticket_id")
  seatIndex     Int       @map("seat_index")
  qrToken       String    @unique @map("qr_token")
  qrUrl         String?   @map("qr_url")
  checkedInAt   DateTime? @map("checked_in_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  ticket        Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@id([ticketId, seatIndex])
  @@index([qrToken])
  @@index([ticketId])
  @@map("ticket_seats")
}

model Suggestion {
  id         BigInt    @id @default(autoincrement())
  fullName   String?   @map("full_name")
  email      String?
  phone      String?
  message    String
  chatId     BigInt?   @map("chat_id")
  reply      String?
  repliedAt  DateTime? @map("replied_at") @db.Timestamptz(6)
  repliedBy  BigInt?   @map("replied_by")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("suggestions")
}

model News {
  id          BigInt   @id @default(autoincrement())
  title       String
  content     String
  imageUrl    String?  @map("image_url")
  publishedAt DateTime @default(now()) @map("published_at") @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("news")
}

model Program {
  id          BigInt    @id @default(autoincrement())
  title       String
  description String?
  speaker     String?
  category    String?
  imageUrl    String?   @map("image_url")
  startTime   String?   @map("start_time")
  endTime     String?   @map("end_time")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("programs")
}

model AdminUser {
  telegramId BigInt   @id @map("telegram_id")
  username   String?
  firstName  String?  @map("first_name")
  isSuper    Boolean  @default(false) @map("is_super")
  addedBy    BigInt?  @map("added_by")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("admins")
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("settings")
}

model GalleryItem {
  id           BigInt   @id @default(autoincrement())
  mediaType    String   @map("media_type")
  mediaUrl     String   @map("media_url")
  thumbnailUrl String?  @map("thumbnail_url")
  caption      String?
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("gallery")
}
